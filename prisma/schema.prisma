generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model admin {
  admin_id                                                  Int                    @id @default(autoincrement())
  admin_name                                                String                 @db.VarChar(255)
  admin_email                                               String                 @unique(map: "admin_email") @db.VarChar(255)
  admin_auth_key                                            String                 @db.VarChar(32)
  admin_password_hash                                       String                 @db.VarChar(255)
  admin_password_reset_token                                String?                @unique(map: "admin_password_reset_token") @db.VarChar(255)
  enable_two_step_auth                                      Boolean?               @default(false)
  admin_status                                              Int                    @default(10) @db.SmallInt
  admin_limited_access                                      Int?                   @default(0) @db.SmallInt
  admin_created_at                                          DateTime               @db.DateTime(0)
  admin_updated_at                                          DateTime               @db.DateTime(0)
  admin_token                                               admin_token[]
  expense_expense_created_byToadmin                         expense[]              @relation("expense_created_byToadmin")
  expense_expense_updated_byToadmin                         expense[]              @relation("expense_updated_byToadmin")
  permission_user                                           permission_user[]
  transfer_bank_advice                                      transfer_bank_advice[]
  transfer_file                                             transfer_file[]
  transfer_file_entry_transfer_file_entry_created_byToadmin transfer_file_entry[]  @relation("transfer_file_entry_created_byToadmin")
  transfer_file_entry_transfer_file_entry_updated_byToadmin transfer_file_entry[]  @relation("transfer_file_entry_updated_byToadmin")
}

model admin_token {
  token_id                 Int       @id @default(autoincrement())
  admin_id                 Int
  token_value              String    @db.VarChar(255)
  token_device             String?   @db.VarChar(255)
  token_device_id          String?   @db.VarChar(255)
  token_status             Int       @db.SmallInt
  token_last_used_datetime DateTime? @db.DateTime(0)
  token_expiry_datetime    DateTime? @db.DateTime(0)
  total_attempt            Boolean?  @default(false)
  otp                      String?   @db.Char(5)
  ip_address               String?   @db.VarChar(45)
  token_created_datetime   DateTime  @db.DateTime(0)
  admin                    admin     @relation(fields: [admin_id], references: [admin_id], onDelete: Cascade, onUpdate: Restrict, map: "fk-admin_token-admin_id")

  @@index([admin_id], map: "idx-admin_token-admin_id")
}

model area {
  area_uuid       String      @id @db.VarChar(60)
  country_id      Int
  area_name_en    String      @db.VarChar(255)
  area_name_ar    String      @db.VarChar(255)
  area_latitude   Decimal?    @db.Decimal(9, 6)
  area_longitude  Decimal?    @db.Decimal(9, 6)
  area_created_at DateTime?   @db.DateTime(0)
  area_updated_at DateTime?   @db.DateTime(0)
  area_created_by String?     @db.VarChar(60)
  area_updated_by String?     @db.VarChar(60)
  country         country     @relation(fields: [country_id], references: [country_id], onUpdate: Restrict, map: "fk-area-country_id")
  candidate       candidate[]
  fulltimer       fulltimer[]
  job             job[]

  @@index([country_id], map: "idx-area-country_id")
}

model attachment {
  attachment_uuid           String                      @id @db.Char(60)
  file_path                 String?                     @db.VarChar(250)
  ticket_attachment         ticket_attachment[]
  ticket_comment_attachment ticket_comment_attachment[]
}

model bank {
  bank_id            Int                  @id @default(autoincrement())
  bank_name          String?              @db.VarChar(100)
  bank_iban_code     String               @db.VarChar(64)
  bank_swift_code    String?              @db.VarChar(100)
  bank_code_abk      Int?
  bank_address       String?              @db.VarChar(100)
  bank_transfer_type String?              @db.Char(3)
  deleted            Int                  @default(0) @db.SmallInt
  candidate          candidate[]
  transfer_candidate transfer_candidate[]
}

model bank_transaction {
  bank_transaction_id        String                       @id @db.Char(60)
  contact_id                 String?                      @db.Char(60)
  currency_rate              Float?
  currency_code              String?                      @default("KWD") @db.Char(3)
  has_attachments            Boolean?                     @default(false)
  is_reconciled              Boolean?                     @default(false)
  line_amount_types          String?                      @db.VarChar(100)
  overpayment_id             String?                      @db.VarChar(255)
  prepayment_id              String?                      @db.VarChar(255)
  reference                  String?                      @db.VarChar(255)
  status                     String?                      @db.VarChar(255)
  status_attribute_string    String?                      @db.VarChar(255)
  sub_total                  Float?
  total                      Float?
  total_tax                  Float?
  type                       String?                      @db.VarChar(255)
  url                        String?                      @db.VarChar(255)
  validation_errors          String?                      @db.VarChar(255)
  date                       DateTime                     @db.DateTime(0)
  created_at                 DateTime                     @db.DateTime(0)
  updated_at                 DateTime                     @db.DateTime(0)
  bank_transaction_contact   bank_transaction_contact?    @relation(fields: [contact_id], references: [contact_id], onDelete: Restrict, onUpdate: Restrict, map: "fk-bank_transaction-contact_id")
  bank_transaction_line_item bank_transaction_line_item[]

  @@index([contact_id], map: "idx-bank_transaction-contact_id")
}

model bank_transaction_contact {
  contact_id       String             @id @db.Char(60)
  name             String?            @db.VarChar(255)
  created_at       DateTime           @db.DateTime(0)
  updated_at       DateTime           @db.DateTime(0)
  bank_transaction bank_transaction[]
}

model bank_transaction_line_item {
  line_item_id         String            @id @db.Char(60)
  bank_transaction_id  String?           @db.Char(60)
  account_code         String?           @db.VarChar(255)
  account_id           String?           @db.VarChar(255)
  description          String?           @db.VarChar(255)
  discount_amount      Float?
  discount_rate        Float?
  item_code            String?           @db.VarChar(255)
  line_amount          Float?
  quantity             Int?
  repeating_invoice_id String?           @db.VarChar(255)
  tax_amount           Float?
  tax_type             String?           @db.VarChar(255)
  unit_amount          Float?
  bank_transaction     bank_transaction? @relation(fields: [bank_transaction_id], references: [bank_transaction_id], onDelete: Cascade, map: "fk-bank_transaction_line_item-bank_transaction_id")

  @@index([bank_transaction_id], map: "idx-bank_transaction_line_item-bank_transaction_id")
}

model blocked_ip {
  ip_uuid    String    @id @db.Char(60)
  ip_address String?   @db.VarChar(45)
  note       String?   @db.VarChar(255)
  created_at DateTime? @db.DateTime(0)
  updated_at DateTime? @db.DateTime(0)
}

model brand {
  brand_uuid             String   @id @db.Char(60)
  company_id             Int?
  brand_name_en          String   @db.VarChar(255)
  brand_name_ar          String   @db.VarChar(255)
  brand_logo             String?  @db.VarChar(255)
  brand_created_datetime DateTime @db.DateTime(0)
  brand_updated_datetime DateTime @db.DateTime(0)
  company                company? @relation(fields: [company_id], references: [company_id], onDelete: Cascade, onUpdate: Restrict, map: "fk-brand-CASCADE")
  store                  store[]

  @@index([company_id], map: "idx-brand-company_id")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model campaign {
  utm_uuid        String            @id @db.Char(60)
  utm_source      String?           @db.VarChar(100)
  utm_medium      String?           @db.VarChar(100)
  utm_campaign    String?           @db.VarChar(100)
  utm_content     String?           @db.VarChar(100)
  utm_term        String?           @db.VarChar(100)
  no_of_signups   Int?
  no_of_clicks    Int?
  investment      Decimal?          @db.Decimal(10, 3)
  total_revenue   Decimal?          @db.Decimal(10, 3)
  created_at      DateTime?         @db.DateTime(0)
  updated_at      DateTime?         @db.DateTime(0)
  candidate       candidate[]
  company_request company_request[]
  contact         contact[]
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
